          "parameters": [
            { "name": "model", "value": "dall-e-3" },
            { "name": "prompt", "value": "={{ JSON.parse($json.message.content).image_prompt }}" },
            { "name": "n", "value": 1 },
            { "name": "size", "value": "1024x1024" }
